# Step 3: Weighted KNN
print("\n--- Step 3: Weighted KNN ---")


print("\n--- Standard vs Weighted KNN and F1 Comparison ---")

k_values = [1, 3, 5, 7, 10, 15]

print("\nK | Std Acc | W Acc | Std F1 | W F1")
print("------------------------------------------------")

standard_accs = []
weighted_accs = []
standard_f1s = []
weighted_f1s = []

# loop through k values to measure how performance changes
for k in k_values:
